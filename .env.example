# Server configuration
PORT=3000
HOST=0.0.0.0

# SPARQL endpoint URL (required)
SPARQL_ENDPOINT=http://localhost:3030/dataset

# Configuration file path (optional, defaults to ./sparql-to-ld.json)
CONFIG_PATH=./sparql-to-ld.json

# CORS settings (optional)
CORS_ORIGIN=*

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
