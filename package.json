{
  "name": "sparql-to-ld",
  "version": "1.2.1",
  "description": "Serve RDF resources' CBDs by translating LD requests into SPARQL DESCRIBE queries.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "sparql-to-ld": "dist/cli/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/cli.ts",
    "build": "tsc",
    "start": "node dist/cli/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts tests/**/*.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrefs/sparql-to-ld.git"
  },
  "keywords": [
    "sparql",
    "rdf",
    "linked-data",
    "cbd",
    "fedbox"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/andrefs/sparql-to-ld/issues"
  },
  "homepage": "https://github.com/andrefs/sparql-to-ld#readme",
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@rdfjs/data-model": "2.1.1",
    "dotenv": "17.3.1",
    "fastify": "5.8.2",
    "n3": "2.0.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sparql-http-client": "3.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/n3": "1.26.1",
    "@types/node": "25.5.0",
    "@types/rdfjs__data-model": "2.0.9",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/ui": "4.1.0",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
